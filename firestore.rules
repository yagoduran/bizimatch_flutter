rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function squadRef(squadId) {
      return /databases/$(database)/documents/squads/$(squadId);
    }

    function agreementRef(agreementId) {
      return /databases/$(database)/documents/agreements/$(agreementId);
    }

    function isSquadMember(squadId) {
      return signedIn()
        && exists(squadRef(squadId))
        && get(squadRef(squadId)).data.members is list
        && get(squadRef(squadId)).data.members.hasAny([request.auth.uid]);
    }

    function isAgreementParticipant(agreementId) {
      return signedIn()
        && exists(agreementRef(agreementId))
        && get(agreementRef(agreementId)).data.participants is list
        && get(agreementRef(agreementId)).data.participants.hasAny([request.auth.uid]);
    }

    match /users/{userId} {
      allow read: if isSelf(userId);
      allow update: if isSelf(userId);
      allow create: if signedIn()
        && request.auth.uid == userId;
      allow delete: if false;
    }

    match /usuarios/{userId} {
      allow read: if isSelf(userId);
      allow update: if isSelf(userId);
      allow create: if signedIn()
        && request.auth.uid == userId;
      allow delete: if false;
    }

    match /squads/{squadId} {
      allow create: if signedIn();
      allow read, update: if isSquadMember(squadId);
      allow delete: if false;
    }

    match /agreements/{agreementId} {
      allow read, update: if isAgreementParticipant(agreementId);
      allow create: if false;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
